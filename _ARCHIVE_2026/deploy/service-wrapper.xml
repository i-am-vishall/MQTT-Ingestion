<service>
  <id>i2v-MQTT-Ingestion-Service</id>
  <name>i2v-MQTT-Ingestion-Service</name>
  <description>Ingests MQTT alerts into the PostgreSQL database.</description>
  <executable>C:\Program Files\nodejs\node.exe</executable>
  <argument>c:\Users\mevis\MQTT-Ingetsion\ingestion-service\src\index.js</argument>
  <workingdirectory>c:\Users\mevis\MQTT-Ingetsion\ingestion-service</workingdirectory>
  <startmode>Automatic</startmode>
  <log mode="roll"></log>
  
  <workingdirectory>%BASE%</workingdirectory>
  <env name="DB_PORT" value="5441"/>
  <env name="DB_HOST" value="127.0.0.1"/>
  <env name="DB_USER" value="postgres"/>
  <env name="DB_NAME" value="mqtt_alerts_db"/>
  <!-- DB_PASSWORD is empty for trust auth -->
  
</service>
