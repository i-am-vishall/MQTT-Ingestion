<service>
	<id>mqttingestionservice.exe</id>
	<name>MQTT Ingestion Service</name>
	<description>Ingests real-time MQTT alerts into PostgreSQL.</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>--harmony</argument>
	<argument>C:\Users\mevis\MQTT-Ingetsion\ingestion-service\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\Users\mevis\MQTT-Ingetsion\ingestion-service\src\index.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>MQTT Ingestion Service wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
