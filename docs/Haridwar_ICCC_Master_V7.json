        {
          "format": "table",
          "rawSql": "\nSELECT \n    CASE \n        WHEN origin_city IN ('UK', 'UA', 'Dehradun') THEN 'Dehradun'\n        WHEN origin_city IN ('UP', 'Lucknow') OR origin_city LIKE 'U0%' THEN 'Lucknow'\n        WHEN origin_city IN ('DL', 'Delhi') THEN 'Delhi'\n        WHEN origin_city IN ('HR', 'Chandigarh') THEN 'Chandigarh'\n        WHEN origin_city IN ('PB', 'Amritsar') THEN 'Amritsar'\n        WHEN origin_city IN ('RJ', 'Jaipur') THEN 'Jaipur'\n        ELSE origin_city\n    END AS \"City\",\n    mode as \"Mode\",\n    SUM(arrival_count) AS \"Arrivals\"\nFROM booking_inflow\nWHERE target_date = CURRENT_DATE\nGROUP BY \"City\", mode\nORDER BY \"Arrivals\" DESC;\n        ",
